DISCORD_TOKEN=your_discord_bot_token_here
# Optional: Set this to develop commands in a specific guild for faster sync
# DISCORD_GUILD_ID=123456789
# Optional: Restrict WASH Crew-only commands (e.g. /start_vote) to members
# with this Discord role. If unset, those commands fail closed: nobody can
# use them until a role is configured here.
# WASH_CREW_ROLE_ID=123456789
# Optional: Default number of nominees /start_vote selects when
# nominee_count isn't explicitly given. Must be between 2 and 10.
# Defaults to 3 if unset. A future setup flow will let WASH Crew configure
# this interactively instead.
# DEFAULT_VOTE_NOMINEE_COUNT=3

# OMDb API key used to resolve IMDb title links
OMDB_API_KEY=
