# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.Python
venv/
.venv/
env/

# Environment variables
.env
.env.*
!.env.example

# Runtime data
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.json
data/*.bak
data/logs/

# Ignore data/backups/ contents but keep the directory itself trackable
# (via data/backups/.gitkeep) so it exists in a fresh clone.
data/backups/*
!data/backups/.gitkeep

# Logs
*.log

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db

# Test/cache
.pytest_cache/
.coverage
htmlcov/

# VS:Code Workspace
*.code-workspace

# Graphic Assets
WatchPartyManager.ai

# Claude (local permission-history files only -- keep .claude/ itself tracked)
.claude/settings.json
.claude/settings.local.json
